# Copy to .env and fill in your values, then run: bash sync_env.sh

# ── Supabase Postgres ────────────────────────────────────────────────────────
ARES_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
ARES_TEST_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me
ACCESS_TOKEN_TTL=1440

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://<backend-ngrok-domain>/auth/google/callback

# ── URLs ─────────────────────────────────────────────────────────────────────
# Backend ngrok domain (Hobby plan static domain)
API_NGROK_URL=https://<backend-ngrok-domain>
# CV ngrok domain (Hobby plan static domain, or same as API if using one tunnel)
CV_NGROK_URL=https://<cv-ngrok-domain>
# http://localhost:8001 if CV runs locally; CV_NGROK_URL if CV runs on Brev
CV_LOCAL_URL=http://localhost:8001
# LAN IP of the machine running the frontend (for phone access)
FRONTEND_URL=http://<local-ip>:3000

# ── CORS ─────────────────────────────────────────────────name────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://<local-ip>:3000

# ── NVIDIA NIM / Nemotron (optional) ─────────────────────────────────────────
NVIDIA_API_KEY=
