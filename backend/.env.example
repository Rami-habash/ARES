# Copy to backend/.env and fill in values. See backend/SUPABASE_SETUP.md.

# ── Supabase Postgres ────────────────────────────────────────────────────────
# Required. Use the SESSION pooler (port 5432) — NOT the transaction pooler.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
ARES_DB_URL=

# Strongly recommended to point at a SEPARATE Supabase project; the test suite
# DROPs and re-creates tables, so this URL must not point at any DB you care about.
ARES_TEST_DB_URL=

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — CHANGE THIS before deploying
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_please

# Token lifetime in minutes (default 1440 = 24h)
ACCESS_TOKEN_TTL=1440

# Google OAuth (optional — email/password works without this)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── External services ────────────────────────────────────────────────────────
# NVIDIA NIM / Nemotron (optional — AI chat falls back to mock if unset)
NVIDIA_API_KEY=

# CV pipeline FastAPI URL
CV_API_BASE=http://localhost:8001
CV_INTERNAL_BASE=http://localhost:8001

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Where the frontend lives — used by the Google OAuth callback redirect
FRONTEND_URL=http://localhost:3000
